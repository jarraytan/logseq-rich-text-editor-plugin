{
  "extends": "@istanbuljs/nyc-config-typescript",
  "all": true,
  "include": ["src/**/*.{js,ts,vue}"],
  "exclude": [
    "src/main.js",
    "src/**/*.d.ts",
    "src/**/__tests__/**",
    "src/**/*.stories.js",
    "src/**/*.stories.ts"
  ],
  "reporter": ["html", "lcov", "text-summary"],
  "check-coverage": true,
  "statements": 80,
  "branches": 75,
  "functions": 80,
  "lines": 80
}
